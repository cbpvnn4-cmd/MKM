# Production Environment Variables for Elevator Company Management System
# Copy this file to .env.prod and fill in the actual values

# Database Configuration
DB_PASSWORD=your_secure_database_password_here
POSTGRES_PASSWORD=your_secure_database_password_here

# Application Security
SECRET_KEY=your_very_long_and_secure_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# Monitoring & Grafana
GRAFANA_PASSWORD=your_grafana_admin_password_here

# Email/SMTP Configuration (for alerts)
SMTP_HOST=smtp.your-email-provider.com
SMTP_USER=your-email@your-company.com
SMTP_PASSWORD=your_email_password_here

# Cloud Storage (for backups)
S3_BACKUP_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Redis / Celery
REDIS_URL=redis://:your_redis_password_here@redis:6379/0
REDIS_PASSWORD=your_redis_password_here

# Monitoring & Alerting
SENTRY_DSN=your_sentry_dsn_here_for_error_tracking
SLACK_WEBHOOK_URL=your_slack_webhook_url_for_notifications

# Domain Configuration
DOMAIN=elevator-company.com

# SSL Certificate Email
CERTBOT_EMAIL=admin@elevator-company.com

# Backup Configuration
BACKUP_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7

# Production URLs
VITE_API_URL=https://api.elevator-company.com
