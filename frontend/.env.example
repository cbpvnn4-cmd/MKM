# ========================================
# Frontend Environment Variables
# نظام السند للمصاعد - إعدادات الواجهة الأمامية
# ========================================

# API Base URL
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# Application Title
VITE_APP_NAME="نظام السند للمصاعد"
VITE_APP_NAME_EN="SANAD ELEVATORS"

# Company Info
VITE_COMPANY_NAME="السند للمصاعد"
VITE_COMPANY_NAME_EN="SANAD ELEVATORS"

# Default Language
VITE_DEFAULT_LANGUAGE=ar

# Timezone
VITE_TIMEZONE=Asia/Riyadh

# Date Format
VITE_DATE_FORMAT=DD/MM/YYYY

# Currency
VITE_DEFAULT_CURRENCY=SAR
VITE_CURRENCY_SYMBOL=ر.س

# Pagination
VITE_DEFAULT_PAGE_SIZE=25

# File Upload Limits (in bytes)
VITE_MAX_FILE_SIZE=104857600

# Features Flags
VITE_ENABLE_PDF_GENERATION=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_PRINT=true
