# ========================================
# نظام السند للمصاعد - إعدادات الإنتاج
# SANAD ELEVATORS - Production Settings
# ========================================

# ----------------------------------------
# Database Configuration
# ----------------------------------------
# PostgreSQL Database Connection
DATABASE_URL="postgresql://postgres:YOUR_SECURE_PASSWORD@localhost:5432/elevator_management"

# ----------------------------------------
# Security Settings (CRITICAL)
# ----------------------------------------
# Generate a new SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production!
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_IN_PRODUCTION
ALGORITHM=HS256

# Token Expiry (7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------------------
# Password Requirements
# ----------------------------------------
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_UPPERCASE=true
REQUIRE_PASSWORD_LOWERCASE=true
REQUIRE_PASSWORD_DIGIT=true
REQUIRE_PASSWORD_SPECIAL=true

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
ENABLE_RATE_LIMITING=true
DISABLE_RATE_LIMIT_IN_DEBUG=false

# ----------------------------------------
# Session Settings
# ----------------------------------------
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=true  # Set to true in production (HTTPS)
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# ----------------------------------------
# CSRF Protection
# ----------------------------------------
ENABLE_CSRF_PROTECTION=true
CSRF_COOKIE_NAME=csrf_token

# ----------------------------------------
# Application Settings
# ----------------------------------------
DEBUG=false
ENVIRONMENT=production
APP_NAME=Elevator Management System
APP_VERSION=1.0.0

# ----------------------------------------
# CORS Settings
# ----------------------------------------
# In production, list only your allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ----------------------------------------
# Email Settings (for notifications)
# ----------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# ----------------------------------------
# File Upload Settings
# ----------------------------------------
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# ----------------------------------------
# Profit Distribution Settings
# ----------------------------------------
DEFAULT_COMPANY_PCT=30.00
DEFAULT_RESERVE_RATE=0.00

# ----------------------------------------
# Optional: AWS S3 for file storage
# ----------------------------------------
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ----------------------------------------
# Optional: Redis for caching/sessions
# ----------------------------------------
# REDIS_URL=redis://localhost:6379/0
